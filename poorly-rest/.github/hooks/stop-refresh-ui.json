{
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": "pwsh -NoProfile -File .github/hooks/scripts/refresh-ui-on-stop.ps1",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/refresh-ui-on-stop.ps1",
        "cwd": ".",
        "timeout": 600
      }
    ]
  }
}
 